{
  "name": "lokaview",
  "version": "0.0.0",
  "description": "Local Office Viewer: a browser-local document viewer for PDF, DOCX, XLSX, PPTX, and CSV files.",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "tsc --noEmit && vite build",
    "preview": "vite preview",
    "typecheck": "tsc --noEmit",
    "lint": "eslint .",
    "test": "vitest run --config vitest.config.ts",
    "deploy": "wrangler deploy"
  },
  "devDependencies": {
    "@cloudflare/workers-types": "^4.20260613.1",
    "@eslint/js": "^10.0.1",
    "@types/node": "^25.9.3",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.2",
    "eslint": "^10.5.0",
    "eslint-plugin-react-hooks": "^7.1.1",
    "eslint-plugin-react-refresh": "^0.5.2",
    "globals": "^17.6.0",
    "typescript": "^6.0.3",
    "typescript-eslint": "^8.61.0",
    "vite": "^8.0.16",
    "vitest": "^4.1.8",
    "wrangler": "^3.114.17"
  },
  "private": true,
  "dependencies": {
    "@aiden0z/pptx-renderer": "^1.1.0",
    "docx-preview": "^0.3.7",
    "fflate": "^0.8.3",
    "lucide-react": "^1.18.0",
    "pdfjs-dist": "^5.7.284",
    "react": "^19.2.7",
    "react-dom": "^19.2.7",
    "read-excel-file": "^9.2.0"
  }
}
